{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            fp.farm_id,\n            p.slug              AS \"slug!\",\n            p.key_de            AS \"name_de!\",\n            p.name_en,\n            c.slug              AS \"group_slug!\",\n            fp.status           AS \"status: StockStatus\",\n            fp.last_confirmed_at\n        FROM farm_products fp\n        JOIN products p ON p.id = fp.product_id\n        JOIN product_categories c ON c.id = p.category_id\n        WHERE fp.farm_id = ANY($1)\n        ORDER BY p.slug\n        ",
