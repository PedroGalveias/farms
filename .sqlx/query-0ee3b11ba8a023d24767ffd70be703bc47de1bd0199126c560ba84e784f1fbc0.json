{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            s.id,\n            s.farm_id,\n            p.slug        AS \"product_slug!\",\n            s.action      AS \"action: SuggestionAction\",\n            s.note,\n            s.submitted_by,\n            s.created_at\n        FROM farm_product_suggestions s\n        JOIN products p ON p.id = s.product_id\n        WHERE s.status = 'PENDING'\n        ORDER BY s.created_at DESC, s.id DESC\n        LIMIT $1\n        ",
